FROM python:3.11-slim

WORKDIR /app

# Install watchmedo (watchdog) + wait-for-it
RUN apt-get update \
  && apt-get install -y --no-install-recommends curl \
  && pip install --upgrade pip watchdog \
  && curl -fsSL https://raw.githubusercontent.com/vishnubob/wait-for-it/master/wait-for-it.sh \
       -o /usr/local/bin/wait-for-it.sh \
  && chmod +x /usr/local/bin/wait-for-it.sh \
  && apt-get purge -y --auto-remove curl \
  && rm -rf /var/lib/apt/lists/*

# Cache dependencies
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy code (overlaid by volume in compose)
COPY . /app

ENTRYPOINT ["/usr/local/bin/wait-for-it.sh", "flashsms-redis:6379", "--"]
CMD ["watchmedo", "auto-restart", "--directory=/app", "--pattern=*.py", "--recursive", "--", "python", "bot_project/main.py"]
